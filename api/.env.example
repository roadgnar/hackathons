# Cyvl Infrastructure Data API credentials.
# Provide EITHER a refresh token (Option A) OR email+password (Option B).
# Option A is required for SSO-only accounts (e.g. Google login).

# --- Option A: refresh token (recommended) ---
# Grab from https://cyvl.app/auth/debug while logged in.
# After first successful run, this value will be auto-rotated and saved here.
CYVL_REFRESH_TOKEN=

# --- Option B: email + password (only if your account has a password set) ---
CYVL_EMAIL=
CYVL_PASSWORD=

# Optional — port for the local Swagger UI server (default 3000)
PORT=3000
